{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor",
    ":disableRateLimiting"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^go\\.mod$/"],
      "matchStrings": ["^go\\s+v?(?<currentValue>[0-9]+(?:\\.[0-9]+)*)"],
      "depNameTemplate": "go",
      "datasourceTemplate": "golang-version"
    }
  ]
}
